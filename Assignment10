// Define Albuquerque roi using FAO GAUL
// This seems less efficient but it's in the instructions...
var gaul2 = ee.FeatureCollection("FAO/GAUL_SIMPLIFIED_500m/2015/level2")
var city = ee.Feature(gaul2
  .filter(ee.Filter.and(
    ee.Filter.eq('ADM1_NAME', 'New Mexico'),
    ee.Filter.eq('ADM2_NAME', 'Bernalillo')
  ))
  .first())
var albuquerqueRoi = city.geometry()
Map.centerObject(albuquerqueRoi, 10)

// Define SR Landsat collection
var sr  = ee.ImageCollection('LANDSAT/LC08/C02/T1_L2')

// This function adds a band for the images' timestamp
function addTimeBand(image) {
  return image.addBands(image.metadata('system:time_start')
    // Convert milliseconds from epoch to years to aid in
    // interpretation of the following trend calculation
    .divide(1000 * 60 * 60 * 24 * 365))
}

// Retrieve SR image collection with time band, NDVI, and LST conversion
function addLstAndNdvi(image) {
  var lst = image.select('ST_B10')
    .multiply(0.00341802).add(149.0)
    .subtract(273.15)
    .rename('lst')

  var nir = image.select('SR_B5').multiply(0.0000275).add(-0.2)
  var red = image.select('SR_B4').multiply(0.0000275).add(-0.2)
  var ndvi = nir.subtract(red)
    .divide(nir.add(red))
    .rename('ndvi')

  return image.addBands(lst).addBands(ndvi)
}

var albuquerqueSr = sr
  .filterBounds(albuquerqueRoi)
  .filterDate('2016-01-01', '2025-12-31')   // filtered to last decade
  .filter(ee.Filter.lt('CLOUD_COVER', 15))
  .map(addTimeBand)
  .map(addLstAndNdvi)

// Visualization: SR true color composite (median)
