// Correlaiton image
var correlationImage = albuquerqueSr
  .select(['lst', 'ndvi'])
  .reduce(ee.Reducer.pearsonsCorrelation())
  .clip(albuquerqueRoi)

// Summary stats
var corrStats = correlationImage.reduceRegion({
  reducer: ee.Reducer.mean(),
  geometry: albuquerqueRoi,
  scale: 300,
  maxPixels: 1e9
})
print('Mean correlation r (LST vs NDVI):', corrStats.get('correlation'))
print('Mean p-value (LST vs NDVI):',   corrStats.get('p-value'))

// Per-image spatial correlation between LST and NDVI pixels
var corrFeatures = albuquerqueSr.map(function(image) {
  var corr = image.select(['lst', 'ndvi']).reduceRegion({
    reducer: ee.Reducer.pearsonsCorrelation(),
    geometry: albuquerqueRoi,
    scale: 300,
    maxPixels: 1e9
  })
  return ee.Feature(null, {
    'correlation': corr.get('correlation'),
    'p-value':     corr.get('p-value'),
    'date':        image.date().millis()
  })
}).filter(ee.Filter.notNull(['correlation', 'p-value']))

var corrChart = ui.Chart.feature.byFeature({
  features: corrFeatures,
  xProperty: 'date',
  yProperties: ['correlation', 'p-value']
})
.setChartType('ScatterChart')
.setOptions({
  title: 'LST–NDVI Pearson Correlation & p-value Over Time, 2016–2025',
  hAxis: {title: 'Date', titleTextStyle: {italic: false, bold: true}},
  vAxis: {title: 'Value', titleTextStyle: {italic: false, bold: true},
    viewWindow: {min: -1, max: 1}},
  lineWidth: 2,
  pointSize: 3,
  colors: ['blue', 'red'],
  series: {
    0: {labelInLegend: 'Pearson r'},
    1: {labelInLegend: 'p-value'}
  }
})
print(corrChart)

