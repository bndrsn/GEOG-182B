// Image Masking example /////////////////////////////////////////////////////////

// Create an NDVI image using Sentinel 2.
var ucla = ee.Geometry.Point(-118.4446, 34.0695);
var uclaImage = ee.ImageCollection('COPERNICUS/S2')
   .filterBounds(ucla)
   .filterDate('2023-08-15', '2023-10-01')
   .first()

var uclaNDVI = uclaImage.normalizedDifference(['B8', 'B4'])

// Implement a threshold.
var uclaVeg=uclaNDVI.gt(0.2) // I used an empirical value here, feel free to change and see the difference 

// Binary mask of non-forest
var vegMask = uclaVeg.eq(1)

// Update the seaVeg mask with the non-forest mask.
var maskedVeg = uclaVeg.updateMask(vegMask);

// Map the updated Veg layer
Map.addLayer(
  maskedVeg,
  {
    min: 0,
    max: 1,
    palette: ['green']
  },
  'Masked Forest Layer'
)
