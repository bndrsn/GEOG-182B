//Let's first look at planar vs. Geodesic coordinate systems
var geodesicBnds = ee.Geometry.Rectangle({coords: [-130, 20, -60, 50], geodesic: true})
var planarBnds = ee.Geometry.Rectangle({coords: [-130, 20, -60, 50], geodesic: false})
Map.addLayer(geodesicBnds,{},'geodesic')
Map.addLayer(planarBnds,{},'planar')

