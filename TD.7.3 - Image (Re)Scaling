// Define a function to display histogram of a band
function showHistogram(image, name, hTitle, band, color, scale) {
  var options = {
    title: 'Histogram of ' + name,
    titleTextStyle: {
      italic: false, 
      bold: true, 
      fontSize: 25
    },
    fontSize: 20,
    hAxis: {
      title: hTitle,
      titleTextStyle: {
        italic: true, 
        bold: true, 
        fontSize: 23
      },
    },
    vAxis: {
      title: 'Count of ' + hTitle,
      titleTextStyle: {
        italic: true, 
        bold: true, 
        fontSize: 23
      },
    },
    legend: {
      position: 'none',
    },
    series: {0: {color: color}}
  }
    
  var histogram = ui.Chart.image.histogram({
    image: image.select(band),
    region: image.geometry(),
    maxBuckets: Math.pow(2, 8),
    scale: scale,
  })
  
  print(histogram
    .setSeriesNames([band])
    .setOptions(options)
  )
}

// Show histograms
showHistogram(image, 'Floating point raster', 'Reflectance like response', 'R', 'red', 100) //Decimal raster
