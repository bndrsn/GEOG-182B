    //.filter(ee.Filter.eq('ADM1_NAME','Siga'))
    // Filter to Ootusi District (Otsu City)
    .filter(ee.Filter.eq('ADM2_NAME','Ootusi'))
    .first()
  )
  .geometry() // Retrieve the geometry from the vector
  .buffer(10000) // Try commenting out the buffer and see what happens?
  .bounds() // Use bounding box to make code more efficient

