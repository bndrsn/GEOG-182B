// Land Surface Temperature ///////////////////////////////////////////////////// 

// Calling a legend function
var myGeeTb = require('users/bodaciouszhou/funcS:addContinuousLegend')

// Retrieve a Landsat scene near UCLA
var ucla = ee.Geometry.Point(-118.4446, 34.0695)

// Retrieve Top of Atmospheric reflectance image
var uclaToa = toa
  .filterBounds(ucla)
  .filterDate('2023-08-15', '2023-10-01')
  .first()

// Retrieve surface reflectance image
var uclaSr = sr
  .filterBounds(ucla)
  .filterDate('2023-08-15', '2023-10-01')
  .first()
   
// Define the visualization parameters.
var vizParamsToa = {
  bands: ['B2', 'B3', 'B4'],
  min: 0,
  max: 0.25,
  gamma: [1, 1, 1]
}
var vizParamsSr = {
  bands: ['SR_B2', 'SR_B3', 'SR_B4'],
  min: 0,
  max: 0.25,
  gamma: [1, 1, 1]
}

// Display TOA reflectance in true color
Map.addLayer(uclaToa.select(['B2','B3','B4']), vizParamsToa, 'TOA true color composite')

// Display SR in true color
Map.addLayer(uclaSr
  .select(['SR_B2','SR_B3','SR_B4'])
  .multiply(0.0000275)
  .add(-0.2), 
  vizParamsSr, 
  'SR true color composite'
)

// Select Band 10 and rename it to land surface temperature
var lst = uclaSr
  .select('ST_B10')
  .rename('lst')
  // DN to LST conversion
  .multiply(0.00341802).add(149.0)

// Define a visualization dictionary
var vizDict = {
  title: 'LST', // Legend title
  loc: 'bottom-right', // Legend placement
  minV: 18, // Minimum value in legend
  maxV: 50, // Maximum value in legend
  mapObj: Map, // Define the map object to add the legend  
  palette: [
      '040274', '040281', '0502a3', '0502b8', '0502ce', '0502e6',
      '0602ff', '235cb1', '307ef3', '269db1', '30c8e2', '32d3ef',
      '3be285', '3ff38f', '86e26f', '3ae237', 'b5e22e', 'd6e21f',
      'fff705', 'ffd611', 'ffb613', 'ff8b13', 'ff6e08', 'ff500d',
      'ff0000', 'de0101', 'c21301', 'a71001', '911003'
    ], // Legend color palette
}

// Display land surface temperature
Map.addLayer(lst
  // K to C
  .subtract(273.15), 
  {
    min: vizDict.minV, // Minimum LST value
    max: vizDict.maxV, // Maximum LST value
    palette: vizDict.palette // Display palette
  }, 
  'Land Surface Temperature 2023'
)

// Add legend using the called function
myGeeTb.addContinuousLegend(vizDict)

// Center map
Map.centerObject(ucla, 11)
